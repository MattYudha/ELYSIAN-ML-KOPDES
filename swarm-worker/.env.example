# =====================================================
# Elysian Swarm Worker - Environment Variables
# =====================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =====================================================

# ----- Redis (shared with Elysian Go Backend) ------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ----- LLM Provider --------------------------------
# Supports any OpenAI-compatible API endpoint.
# Recommended: OpenAI (gpt-4o-mini) or Aliyun Qwen (qwen-plus)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini

# For Aliyun Qwen (alternative, lower cost):
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus

# ----- Elysian Go Backend Webhook ------------------
# URL that the swarm worker will POST results back to.
# Use host.docker.internal if running inside Docker.
ELYSIAN_WEBHOOK_BASE=http://localhost:7777
